# --- DEVELOPMENT / CUSTOM APP ---
PORT=3001
NODE_ENV=development

HOST=https://your-app-host.example.com
APP_URL=https://your-app-host.example.com

SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_SCOPES=read_discounts,write_discounts,read_orders,read_products,read_customers,write_customers
SHOPIFY_API_VERSION=2025-10
SHOPIFY_REDIRECT_URL=https://your-app-host.example.com/auth/callback
SHOPIFY_WEBHOOK_SECRET=

JWT_SECRET=
GOOGLE_SHEET_SECRET=

# Make.com scenario webhook that emails members their discount link
MAKE_WEBHOOK_URL=

# Make.com webhook for syncing completed order data to Google Sheets
MAKE_ORDER_SYNC_WEBHOOK_URL=

# Make.com webhook for 48hr expiry reminder email
MAKE_EXPIRY_REMINDER_WEBHOOK_URL=

# Make.com webhook for post-expiry re-engagement email
MAKE_EXPIRY_NOTIFICATION_WEBHOOK_URL=

# Make.com webhook notifying claimed-not-redeemed members a campaign ended
MAKE_CAMPAIGN_ENDED_WEBHOOK_URL=

DATABASE_URL="postgresql://user:password@host:5432/dbname"
