generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Shop {
  id          Int       @id @default(autoincrement())
  shopDomain  String    @unique
  accessToken String
  scope        String?
  installed    Boolean   @default(false)
  uninstalledAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  settings     ShopSettings?
  campaigns   Campaign[]
  memberShopifyLinks MemberShopifyLink[]
}

model Campaign {
  id                    Int          @id @default(autoincrement())
  shopId                Int
  shop                  Shop         @relation(fields: [shopId], references: [id])

  name                  String
  slug                  String       @unique

  discountType          String       @default("percentage")
  discountValue         Float

  maxRedemptionsPerUser Int?         @default(1)
  maxRedemptions        Int?

  targetAudience        String       @default("all")

  active                Boolean      @default(true)
  startsAt              DateTime?
  validForDays          Int          @default(30)

  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  redemptions           Redemption[]
  filters               CampaignFilter[]
  shopifySegmentId      String?

  discountCode          String?
  discountLink          String?
  shopifyDiscountId     String?
}

model Redemption {
  id               Int       @id @default(autoincrement())
  campaignId       Int
  campaign         Campaign  @relation(fields: [campaignId], references: [id])

  memberId         Int
  member           Member    @relation(fields: [memberId], references: [id])
  status           String    @default("pending")

  accessGrantedAt  DateTime  @default(now())
  accessExpiresAt  DateTime?
  reminderSentAt   DateTime?

  shopifyOrderId   String?
  orderAmount      Float?
  orderCompletedAt DateTime?
}

model Member {
  id              Int       @id @default(autoincrement())
  email           String    @unique
  firstName       String?
  lastName        String?

  role            String
  country         String?
  resort          String?

  yearsExperience Int?
  socialLinks     Json?
  qualifications  String[]  @default([])

  verified        Boolean   @default(false)
  verifiedAt      DateTime?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  redemptions     Redemption[]
  shopifyLinks    MemberShopifyLink[]
}

model MemberShopifyLink {
  id                Int     @id @default(autoincrement())
  memberId          Int
  member            Member  @relation(fields: [memberId], references: [id])
  shopId            Int
  shop              Shop    @relation(fields: [shopId], references: [id])
  shopifyCustomerId String

  @@unique([memberId, shopId])
}

model CampaignFilter {
  id         Int      @id @default(autoincrement())
  campaignId Int
  campaign   Campaign @relation(fields: [campaignId], references: [id])

  filterType String
  value      String

  @@index([campaignId])
}

model ShopSettings {
  id                 Int       @id @default(autoincrement())
  shopId             Int       @unique
  shop               Shop      @relation(fields: [shopId], references: [id])

  categories         String[]  @default([]) // product category handles

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}